def clean_phone(phone):
    phone = str(phone).strip()

    if phone == "" or phone.lower() == "none":
        return None

    if phone.startswith("+"):
        return phone

    if len(phone) == 10:
        return "+91" + phone

    if not phone.startswith("+"):
        phone = "+91" + phone

    return phone

def send_whatsapp(phone, name, status):
    try:
        phone = clean_phone(phone)
        if not phone:
            return

        message = (
            f"📢 Attendance Update\n\n"
            f"Name: {name}\n"
            f"Status: {status}\n"
            f"Date: {date.today()}"
        )

        kit.sendwhatmsg_instantly(
            phone_no=phone,
            message=message,
            wait_time=15,
            tab_close=True,
            close_time=5
        )

    except Exception as e:
        print("WhatsApp Error:", e)
        
def dataset_creator():

    face_cascade = cv2.CascadeClassifier(
        cv2.data.haarcascades + "haarcascade_frontalface_default.xml"
    )

    if selected_id == 0:
        messagebox.showerror("Error", "Please select a student first")
        return

    user_id = selected_id
    user_name = name_var.get()

    cam = cv2.VideoCapture(0)

    path = f"faces/{user_id}_{user_name}"
    os.makedirs(path, exist_ok=True)

    count = 0

    while True:
        ret, frame = cam.read()

        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        faces = face_cascade.detectMultiScale(gray, 1.3, 5)

        for (x, y, w, h) in faces:
            count += 1

            cv2.imwrite(
                f"{path}/{count}.jpg",
                gray[y:y+h, x:x+w]
            )

            cv2.rectangle(
                frame,
                (x, y),
                (x+w, y+h),
                (0, 255, 0),
                2
            )

        cv2.imshow("Dataset Capture", frame)

        if cv2.waitKey(1) == 13 or count >= 50:
            break

    cam.release()
    cv2.destroyAllWindows()

    messagebox.showinfo(
        "Success",
        f"{count} face images captured"
    )

def train_model():
    try:
        messagebox.showinfo("Debug", "Training Started")

        recognizer = cv2.face.LBPHFaceRecognizer_create()

        faces = []
        labels = []

        for folder in os.listdir("faces"):
            path = os.path.join("faces", folder)

            if not os.path.isdir(path):
                continue

            messagebox.showinfo("Folder Found", folder)

            label = int(folder.split("_")[0])

            for img in os.listdir(path):
                img_path = os.path.join(path, img)

                image = Image.open(img_path).convert("L")
                img_np = np.array(image, "uint8")

                faces.append(img_np)
                labels.append(label)

        messagebox.showinfo(
            "Debug",
            f"Faces Loaded: {len(faces)}"
        )

        recognizer.train(faces, np.array(labels))

        os.makedirs("trainer", exist_ok=True)
        recognizer.save("trainer/classifier.xml")

        messagebox.showinfo(
            "Success",
            "Model Trained Successfully"
        )

    except Exception as e:
        messagebox.showerror("Train Error", str(e))
        
def face_recognition():
    try:
        import cv2
        import os
        import sqlite3
        from datetime import date, datetime

        # ---------- CHECK MODEL ----------
        model_path = "trainer/classifier.xml"
        if not os.path.exists(model_path):
            messagebox.showerror("Error", "Model not found. Please train first.")
            return

        # ---------- FACE DETECTOR ----------
        face_cascade = cv2.CascadeClassifier(
            cv2.data.haarcascades + "haarcascade_frontalface_default.xml"
        )

        recognizer = cv2.face.LBPHFaceRecognizer_create()
        recognizer.read(model_path)

        cam = cv2.VideoCapture(0)

        today = date.today().strftime("%Y-%m-%d")

        while True:
            ret, frame = cam.read()
            if not ret:
                break

            gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

            faces = face_cascade.detectMultiScale(gray, 1.3, 5)

            for (x, y, w, h) in faces:
                face = gray[y:y+h, x:x+w]

                id_, conf = recognizer.predict(face)

                name = "Unknown"

                if conf < 70:
                    conn = sqlite3.connect("student.db")
                    cur = conn.cursor()

                    cur.execute("SELECT name, phone FROM students WHERE id=?", (id_,))
                    data = cur.fetchone()

                    if data:
                        name, phone = data

                        # ---------- AUTO ATTENDANCE (NO DUPLICATE) ----------
                        cur.execute("""
                            SELECT * FROM attendance
                            WHERE student_id=? AND date=?
                        """, (id_, today))

                        already_marked = cur.fetchone()

                        if not already_marked:
                            cur.execute("""
                                INSERT INTO attendance(student_id, date, status)
                                VALUES(?, ?, 'Present')
                            """, (id_, today))

                            conn.commit()

                            # update dashboard safely
                            try:
                                update_dashboard()
                            except:
                                pass

                            print(f"[ATTENDANCE] Marked Present for {name}")

                            # OPTIONAL WHATSAPP
                            try:
                                if phone and phone != "None":
                                    if not str(phone).startswith("+91"):
                                        phone = "+91" + str(phone)

                                    send_whatsapp(phone, name, "Present")
                            except:
                                pass

                    conn.close()

                text = f"{name} ({id_})" if conf < 70 else "Unknown"

                cv2.rectangle(frame, (x, y), (x+w, y+h), (0, 255, 0), 2)
                cv2.putText(frame, text, (x, y-10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 0, 0), 2)

            cv2.imshow("Face Recognition Attendance", frame)

            if cv2.waitKey(1) == 13:  # Enter key
                break

        cam.release()
        cv2.destroyAllWindows()

    except Exception as e:
        messagebox.showerror("Recognition Error", str(e))

def mark_absent_students():
    try:
        conn = sqlite3.connect("student.db")
        cur = conn.cursor()

        current_date = datetime.now().strftime("%Y-%m-%d")

        cur.execute("SELECT id, name, phone FROM students")
        students = cur.fetchall()

        for student_id, student_name, phone in students:

            # check attendance already exists
            cur.execute("""
                SELECT *
                FROM attendance
                WHERE student_id=? AND date=?
            """, (student_id, current_date))

            record = cur.fetchone()

            if not record:

                # mark absent
                cur.execute("""
                    INSERT INTO attendance(student_id, date, status)
                    VALUES(?, ?, ?)
                """, (student_id, current_date, "Absent"))

                conn.commit()
                winsound.MessageBeep()

                winsound.Beep(700, 500)

                # ---------------- WHATSAPP ----------------
                try:
                    phone = str(phone).strip()

                    # clean phone safely
                    if phone == "" or phone.lower() == "none":
                        continue

                    if not phone.startswith("+"):
                        phone = "+91" + phone

                    message = f"{student_name} is ABSENT today ({current_date})"

                    kit.sendwhatmsg_instantly(
                        phone_no=phone,
                        message=message,
                        wait_time=10,
                        tab_close=True,
                        close_time=5
                    )

                except Exception as e:
                    print("WhatsApp Error:", e)

        conn.close()
        update_dashboard()

        messagebox.showinfo(
            "Success",
            "Absent students marked successfully")
    except Exception as e:
        messagebox.showerror("Error", str(e))
    

