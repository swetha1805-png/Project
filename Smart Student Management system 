def clear_fields():
    global selected_id
    name_var.set("")
    dept_var.set("")
    year_var.set("")
    phone_var.set("")
    subject_var.set("")
    marks_var.set("")
    selected_id = 0


def view_students():
    conn = sqlite3.connect("student.db")
    cur = conn.cursor()
    cur.execute("SELECT * FROM students")
    rows = cur.fetchall()
    conn.close()

    tree.delete(*tree.get_children())
    for r in rows:
        tree.insert("", END, values=r)

def search_student():

    key = search_var.get()

    conn = sqlite3.connect("student.db")
    cur = conn.cursor()

    cur.execute("""
    SELECT * FROM students
    WHERE name LIKE ?
    OR department LIKE ?
    OR phone LIKE ?
    """, (
        f"%{key}%",
        f"%{key}%",
        f"%{key}%"))

    rows = cur.fetchall()
    conn.close()

    tree.delete(*tree.get_children())

    for row in rows:
        tree.insert("", END, values=row)


def save_student():
    if name_var.get() == "" or dept_var.get() == "":
        messagebox.showerror("Error", "Fill all fields")
        return

    conn = sqlite3.connect("student.db")
    cur = conn.cursor()

    cur.execute("""
        INSERT INTO students(name, department, year, phone, subject, marks)
        VALUES(?,?,?,?,?,?)
    """, (
        name_var.get(),
        dept_var.get(),
        year_var.get(),
        phone_var.get(),
        subject_var.get(),
        int(marks_var.get()) if marks_var.get().isdigit() else 0
    ))

    conn.commit()
    conn.close()

    messagebox.showinfo("Success", "Student Added")
    view_students()
    update_dashboard()
    clear_fields()
    
def update_student():
    global selected_id

    if selected_id == 0:
        messagebox.showerror("Error", "Select student")
        return

    conn = sqlite3.connect("student.db")
    cur = conn.cursor()
    cur.execute("""
    UPDATE students
    SET name=?, department=?, year=?, phone=?, subject=?, marks=?
    WHERE id=?
""", (
    name_var.get(),
    dept_var.get(),
    int(year_var.get()) if year_var.get().isdigit() else 0,
    phone_var.get(),
    subject_var.get(),
    int(marks_var.get()) if marks_var.get().isdigit() else 0,
    selected_id
))
    
    conn.commit()
    conn.close()

    messagebox.showinfo("Success", "Student Updated")
    view_students()
    clear_fields()
    
